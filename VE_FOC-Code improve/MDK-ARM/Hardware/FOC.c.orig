{
//	SendArray[0] = p1->Vq;
//	SendArray[1] = p1->Vd;
//	SendArray[2] = p1->angle;

	SendArray[0] = p1->Ia;
	SendArray[1] = p1->Ib;
	SendArray[2] = p1->Ic;
	
